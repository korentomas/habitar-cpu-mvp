# Copy to .env and fill in. On Render, set these in the dashboard.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require
SECRET_KEY=change-me-to-a-long-random-string
REQUIRED_CREDITS=10
APP_NAME=Módulo Habitar

# Optional SMTP. If unset, emails are printed to the server log (MVP-safe).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Modulo Habitar <no-reply@example.com>
