# Copy to .env and fill in. On Render, set these in the dashboard.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require
# REQUIRED. Generate a strong value: python -c "import secrets;print(secrets.token_urlsafe(32))"
# If unset/insecure, the app generates a random ephemeral key (sessions reset on restart).
SECRET_KEY=
REQUIRED_CREDITS=10
APP_NAME=Módulo Habitar
# Set to 1 in production (HTTPS) to send the session cookie only over TLS.
SESSION_HTTPS_ONLY=

# Optional SMTP. If unset, emails are printed to the server log (MVP-safe).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Modulo Habitar <no-reply@example.com>
